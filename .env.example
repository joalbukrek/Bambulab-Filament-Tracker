# Copy to .env or export these variables before running `bambu-track listen`.
BAMBU_HOST=192.168.1.50
BAMBU_SERIAL=YOUR_PRINTER_SERIAL
BAMBU_ACCESS_CODE=YOUR_LAN_ACCESS_CODE
BAMBU_USERNAME=bblp
BAMBU_MQTT_PORT=8883
BAMBU_DB_PATH=./data/filament.sqlite3

# Optional. If true, also subscribe to device/<serial>/request so the tracker can
# capture Bambu Studio/Handy `ams_mapping` print-start messages when the broker
# allows it.
BAMBU_MONITOR_REQUESTS=false

# Optional Bambu Cloud enrichment. This is used only for prints that report a
# real MQTT task_id. It can fetch Bambu's cloud task weight/amsDetailMapping,
# which local MQTT does not expose.
BAMBU_CLOUD_ENABLED=false
BAMBU_CLOUD_EMAIL=
BAMBU_CLOUD_PASSWORD=
BAMBU_CLOUD_ACCESS_TOKEN=
BAMBU_CLOUD_BASE_URL=https://api.bambulab.com/v1

# Optional Google Sheets sync. The webhook URL comes from a Google Apps Script
# web app deployed from docs/google_apps_script.gs.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_SECRET=change-me
GOOGLE_SHEETS_SYNC_ON_EVENT=false
GOOGLE_SHEETS_MIN_INTERVAL_SECONDS=60
